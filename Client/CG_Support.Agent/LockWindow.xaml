<Window x:Class="CG_Support.Agent.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pantalla Bloqueada" 
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#0F1018"
        Focusable="True">
    
    <Grid>
        <!-- Fondo Gradiente Neon Oscuro Premium -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#090A0F" Offset="0.0"/>
                <GradientStop Color="#161824" Offset="0.5"/>
                <GradientStop Color="#090A0F" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Candado Neon Animado / Estilizado -->
            <Border Width="80" Height="80" CornerRadius="40" Background="#1E2030" BorderBrush="#E63946" BorderThickness="2" Margin="0,0,0,20">
                <TextBlock Text="🔒" FontSize="36" Foreground="#E63946" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
            </Border>
            
            <TextBlock Text="PANTALLA BLOQUEADA" Foreground="#E63946" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Clase en curso. Por favor, presta atención al tutor." Foreground="#8B8D98" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            <TextBlock Text="Teclado y ratón deshabilitados temporalmente." Foreground="#404354" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
