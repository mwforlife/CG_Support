<Window x:Class="CG_Support.Tutor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CG_Support.Tutor"
        mc:Ignorable="d"
        Title="CG_Support - Panel de Control del Tutor" 
        Height="720" Width="1200"
        Background="#0F1018"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Estilo de Botón Premium Redondeado -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#25283C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#353A56"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E2030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botones de Acción Destacados (Ej: Bloquear/Desbloquear) -->
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#3A86FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5C9AFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E63946"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5C6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#2A9D8F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#43C1B2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 0: Top Header -->
            <RowDefinition Height="70"/>
            <!-- 1: Main Control Grid -->
            <RowDefinition Height="*"/>
            <!-- 2: Bottom Status Bar -->
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Border Grid.Row="0" Background="#161824" BorderBrush="#25283C" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Titulo & Estado -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CG_SUPPORT" Foreground="#3A86FF" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="|" Foreground="#404354" FontSize="18" Margin="10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Tutor" Foreground="#8B8D98" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    
                    <!-- LED Indicador de Estado -->
                    <Ellipse x:Name="LedConnection" Width="10" Height="10" Fill="#FF3B30" Margin="0,2,5,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus" Text="Desconectado (Iniciando servidor...)" Foreground="#8B8D98" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Acciones Rápidas -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚡ Wake-on-LAN" Style="{StaticResource SuccessButton}" Click="BtnWol_Click" Margin="0,0,8,0"/>
                    <Button Content="🔒 Bloquear Todo" Style="{StaticResource DangerButton}" Click="BtnLockAll_Click" Margin="0,0,8,0"/>
                    <Button Content="🔓 Desbloquear Todo" Style="{StaticResource ActionButton}" Click="BtnUnlockAll_Click" Margin="0,0,8,0"/>
                    <Button Content="🌐 Bloquear Internet" Style="{StaticResource DangerButton}" Click="BtnBlockWeb_Click" Margin="0,0,8,0"/>
                    <Button Content="✅ Desbloquear Internet" Style="{StaticResource SuccessButton}" Click="BtnAllowWeb_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Panel (Grilla de Computadores) -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="15">
            <ItemsControl x:Name="StudentsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" Margin="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Tarjeta de PC Estudiante -->
                        <Border Width="220" Height="190" Margin="10" CornerRadius="8" Background="#161824" BorderBrush="#25283C" BorderThickness="1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" CommandParameter="{Binding}" MouseAction="LeftDoubleClick"/>
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <!-- Header: Hostname/IP -->
                                    <RowDefinition Height="30"/>
                                    <!-- Screen Stream Area -->
                                    <RowDefinition Height="*"/>
                                    <!-- Footer: Info / Browser URL -->
                                    <RowDefinition Height="35"/>
                                </Grid.RowDefinitions>

                                <!-- Header Card -->
                                <Border Grid.Row="0" Background="#1E2030" CornerRadius="8,8,0,0" Padding="10,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Hostname}" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding UserName}" Foreground="#8B8D98" FontSize="10" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Screen Capture Area -->
                                <Grid Grid.Row="1" Background="#0C0D13">
                                    <!-- Mostrar imagen si está transmitiendo -->
                                    <Image Source="{Binding ScreenImage}" Stretch="Uniform" StretchDirection="DownOnly" Margin="2"/>
                                    
                                    <!-- Fallback si no hay stream o si está bloqueado -->
                                    <Border Visibility="{Binding ScreenImage, Converter={StaticResource NullToVisibilityConverter}}" Background="#0C0D13">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <!-- Icono Candado / Estado -->
                                            <TextBlock Text="💻" FontSize="36" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding IpAddress}" Foreground="#404354" FontSize="10" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Overlay de Pantalla Bloqueada -->
                                    <Border Background="#CCFF3B30" Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="🔒 LOCK" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Pantalla Bloqueada" Foreground="#FFFFFF" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Footer Card -->
                                <Border Grid.Row="2" Background="#1E2030" CornerRadius="0,0,8,8" Padding="10,0" BorderBrush="#25283C" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ActiveWindow}" Foreground="#8B8D98" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip="{Binding ActiveWindow}"/>
                                        <!-- Botones rápidos de control individual -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="👁️" Width="20" Height="20" Margin="2,0" Background="Transparent" Foreground="#8B8D98" BorderThickness="0" FontSize="10" Click="BtnMonitorIndividual_Click" Tag="{Binding}" ToolTip="Monitorear / Controlar"/>
                                            <Button Content="🔒" Width="20" Height="20" Margin="2,0" Background="Transparent" Foreground="#8B8D98" BorderThickness="0" FontSize="10" Click="BtnLockIndividual_Click" Tag="{Binding}" ToolTip="Bloquear/Desbloquear"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#161824" BorderBrush="#25283C" BorderThickness="0,1,0,0" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtInfoFooter" Text="Listo - Servidor corriendo localmente en el puerto 3000" Foreground="#4A4E69" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="TxtCounters" Text="PCs Conectados: 0 / 150" Foreground="#4A4E69" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
